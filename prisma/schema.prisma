// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  plan          String   @default("basic")

  pendingDeathVerificationAt DateTime?
  deceasedAt                 DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  contacts        Contact[]
  messages        Message[]
  arrangements    Arrangement[]
  timelineItems   TimelineItem[]
  vaultItems      VaultItem[]
  executor        Executor?
  photos          Photo[]
  settings        Settings?
  messageInvites  MessageInvite[]
  contributions   Contribution[]
}

model Contact {
  id           String   @id @default(cuid())
  userId       String
  name         String
  email        String?
  phone        String?
  relationship String?
  isExecutor   Boolean  @default(false)
  isBackup     Boolean  @default(false)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model Message {
  id              String    @id @default(cuid())
  userId          String

  recipientName   String
  recipientEmail  String?

  type            String    @default("letter")
  subject         String?
  content         String?
  mediaUrl        String?
  mediaBlobPath   String?
  mediaDurationSec Int?

  // Zip 2c.3: trim handles for video playback. Inclusive seconds.
  // Both null = play full. When set, the viewer enforces these bounds.
  mediaTrimStartSec Int?
  mediaTrimEndSec   Int?

  triggerDate     DateTime?
  state           String    @default("drafting")
  approvalPromptedAt DateTime?
  approvalExpiresAt  DateTime?
  sentAt          DateTime?
  archivedAt      DateTime?

  deliveryToken   String?   @unique
  approvalToken   String?   @unique
  approvalRemindersSent Int  @default(0)

  // Zip 2c.6: recipient link controls
  // viewCount  — cumulative recipient page-views since delivery. Incremented
  //              on every GET /m/[token]. Visible to the sender on the
  //              dashboard so they can spot unexpected sharing.
  // linkRevokedAt — when set, the /m/[token] page shows "no longer available"
  //                 instead of the message. Sender flips this from their
  //                 dashboard.
  viewCount       Int       @default(0)
  linkRevokedAt   DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([state, triggerDate])
  @@index([deliveryToken])
  @@index([approvalToken])
}

model MessageInvite {
  id              String    @id @default(cuid())
  userId          String
  token           String    @unique
  contributorName String
  contributorEmail String?
  message         String?
  expiresAt       DateTime
  revokedAt       DateTime?
  lastUsedAt      DateTime?
  useCount        Int       @default(0)
  createdAt       DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id])
  contributions   Contribution[]

  @@index([userId])
  @@index([token])
}

model Contribution {
  id              String    @id @default(cuid())
  userId          String
  inviteId        String

  contributorName String
  contributorNote String?

  type            String
  content         String?
  mediaUrl        String?
  mediaBlobPath   String?
  mediaDurationSec Int?

  // Zip 2c.3: trim handles. Same semantics as Message.
  mediaTrimStartSec Int?
  mediaTrimEndSec   Int?

  viewedByUser    Boolean   @default(false)
  importedToTimelineItemId String?
  archivedAt      DateTime?

  // Zip 2c.6: timestamp of the new-contribution notification email sent
  // for this contribution. Used for 15-min per-contributor dedupe — if
  // a contributor submits 3 items in 5 minutes we only email the owner
  // once. Null = email never sent (either because owner has notifications
  // off, or because dedupe suppressed it).
  notifyEmailedAt DateTime?

  createdAt       DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id])
  invite          MessageInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([inviteId])
}

model TimelineItem {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  title     String
  story     String?
  mediaUrl  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  photos    Photo[]
}

model Photo {
  id             String        @id @default(cuid())
  userId         String
  timelineItemId String?
  url            String
  thumbnailUrl   String?
  blobPath       String
  caption        String?
  width          Int?
  height         Int?
  sizeBytes      Int?
  order          Int           @default(0)
  createdAt      DateTime      @default(now())
  user           User          @relation(fields: [userId], references: [id])
  timelineItem   TimelineItem? @relation(fields: [timelineItemId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timelineItemId])
}

// Zip 2d.1: Arrangements foundation. Rebuilt from the original four-field
// placeholder (type/vendor/contact/notes) into the proper module shape.
//
//   category                  — one of: disposition, service, notifications,
//                               legal, wishes. Drives section grouping in
//                               the UI.
//   title                     — display name of the checklist item.
//   status                    — planned | in-progress | arranged |
//                               not-applicable. 2d.2 lets users move items
//                               along. 2d.1 leaves everything at "planned".
//   isCore                    — flags the four essentials (disposition
//                               preference, will location, funeral home,
//                               executor contact). Soft visual emphasis,
//                               not a hard requirement.
//   executorVisibleAfterDeath — per-entry switch for what becomes visible
//                               to the executor on death. Default true.
//                               The mechanism that flips visibility lands
//                               in the Executor module (2e).
//   structuredData            — Json bag for per-type fields (will location,
//                               funeral home contract #, bank account
//                               last-4, etc.). Schema evolves without
//                               migrations.
//   vendor / contact / notes  — kept from the original schema. notes is
//                               where the user's freeform overflow lives.
//                               2d.1 seeds the column with the seed-file
//                               hint as a paper trail, but the UI pulls
//                               hints from code at render time.
//   sortOrder                 — int that packs category index + item
//                               position, with core items floated up.
model Arrangement {
  id                        String   @id @default(cuid())
  userId                    String
  category                  String
  title                     String
  status                    String   @default("planned")
  isCore                    Boolean  @default(false)
  executorVisibleAfterDeath Boolean  @default(true)
  structuredData            Json?
  vendor                    String?
  contact                   String?
  notes                     String?
  sortOrder                 Int      @default(0)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, category])
}

model VaultItem {
  id            String   @id @default(cuid())
  userId        String
  label         String
  encryptedData String
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
}

model Executor {
  id             String    @id @default(cuid())
  userId         String    @unique
  name           String
  email          String
  phone          String?
  verified       Boolean   @default(false)
  certUploadedAt DateTime?
  unlockedAt     DateTime?
  createdAt      DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id])
}

model Settings {
  id              String   @id @default(cuid())
  userId          String   @unique
  pageTurnStyle   String   @default("fade")
  fontScale       String   @default("normal")
  highContrast    Boolean  @default(false)
  ttsEnabled      Boolean  @default(false)
  sttEnabled      Boolean  @default(false)
  reducedMotion   Boolean  @default(false)

  // Zip 2c.3: user's chosen TTS voice. Stored as the Web Speech API's
  // opaque voiceURI string. Null = auto-pick best available.
  preferredVoiceURI String?

  // Zip 2c.6: send the owner an email when a new contribution arrives.
  // Default on — silent submissions feel uncared-for. Honored at email
  // send time; per-contributor dedupe still applies even when enabled.
  notifyOnContribution Boolean @default(true)

  // Zip 2d.1: Arrangements module section acknowledgements + seed stamp.
  //   arrSeededAt — set the first time the user visits /dashboard/arrangements.
  //                 Presence of a value is the "already seeded" signal; the
  //                 seed is a no-op on subsequent visits.
  //   arrAck*     — per-category "I've considered this section" flags.
  //                 The UI to flip these lands in 2d.3; columns exist now
  //                 so 2d.3 needs no migration.
  arrSeededAt          DateTime?
  arrAckDisposition    Boolean   @default(false)
  arrAckService        Boolean   @default(false)
  arrAckNotifications  Boolean   @default(false)
  arrAckLegal          Boolean   @default(false)
  arrAckWishes         Boolean   @default(false)

  // Optional note rendered at the top of the executor preview (2d.4) for
  // whoever opens this section after the user is gone. Edited in-place on
  // /dashboard/arrangements. Null/empty = no note.
  arrFinalMessage      String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])
}
